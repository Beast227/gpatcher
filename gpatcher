#!/bin/sh
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
export PYTHONPATH="$SCRIPT_DIR/src:$PYTHONPATH"

if command -v python3 >/dev/null 2>&1; then
    exec python3 -m gpatcher "$@"
elif command -v python >/dev/null 2>&1; then
    exec python -m gpatcher "$@"
else
    echo "[err] gpatcher requires Python to run. Please install Python and ensure it is in your PATH." >&2
    exit 1
fi
